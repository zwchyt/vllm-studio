# vLLM Studio Configuration
# Copy this file to .env.local in the project root and modify as needed.
#
# On Windows (PowerShell):
#   Copy-Item .env.example .env.local

# =============================================================================
# Controller Settings
# =============================================================================

VLLM_STUDIO_HOST=127.0.0.1
VLLM_STUDIO_PORT=8080

# Set an API key if binding to a non-loopback address
# VLLM_STUDIO_API_KEY=

# Inference backend port
VLLM_STUDIO_INFERENCE_PORT=8000

# Enable mock inference for testing without a real LLM
# VLLM_STUDIO_MOCK_INFERENCE=true

# =============================================================================
# Paths (use Windows format on Windows, e.g. E:\models)
# =============================================================================

# Directory containing model weights
# VLLM_STUDIO_MODELS_DIR=E:\models

# Data directory for recipes and chat history
VLLM_STUDIO_DATA_DIR=./data

# =============================================================================
# Backend Settings
# =============================================================================

# llama.cpp server binary (set if llama-server.exe is not on PATH)
# VLLM_STUDIO_LLAMA_BIN=F:\llama-b9016\llama-server.exe

# Pi agent binary (set if pi.cmd is not on PATH)
# VLLM_STUDIO_PI_BINARY=

# =============================================================================
# Activation Policy
# =============================================================================

# load_if_idle: reject request if a different model is already running
# switch_on_request: evict current model and load the requested one
# OPENAI_MODEL_ACTIVATION_POLICY=load_if_idle

# =============================================================================
# Advanced
# =============================================================================

# Strict OpenAI model matching (only configured recipes are routable)
# VLLM_STUDIO_STRICT_OPENAI_MODELS=false

# Allow agent file tools to fall back to local filesystem
# VLLM_STUDIO_AGENT_FS_LOCAL_FALLBACK=false

# Exa AI API key for web search
# EXA_API_KEY=
